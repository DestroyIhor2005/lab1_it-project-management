{
  "rewrites": [
    {
      "source": "/api/coingecko/:path*",
      "destination": "/api/coingecko?path=:path*"
    },
    {
      "source": "/api/posthog",
      "destination": "https://eu.i.posthog.com"
    },
    {
      "source": "/api/posthog/:path*",
      "destination": "https://eu.i.posthog.com/:path*"
    },
    {
      "source": "/api/binance/:path*",
      "destination": "https://api.binance.com/api/v3/:path*"
    }
  ]
}